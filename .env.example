# ============================================================
# better-rag Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ── Application ──
DEBUG=false
LOG_LEVEL=INFO

# ── LLM Provider (azure_openai | anthropic) ──
LLM_PROVIDER=azure_openai
LLM_EXPENSIVE_MODEL=gpt-4o
LLM_CHEAP_MODEL=gpt-4o-mini

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# Anthropic (if using LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# LLM Rate Limits
LLM_RATE_LIMIT_RPM=500
LLM_RATE_LIMIT_TPM=150000
LLM_CONCURRENT_REQUESTS=50

# ── Microsoft Graph / SharePoint ──
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SITE_URLS=[]
# JSON list: [{"site_id":"...","drive_id":"..."}]
SHAREPOINT_DRIVES=[]

# ── Azure Blob Storage ──
BLOB_ACCOUNT_URL=https://youraccount.blob.core.windows.net
BLOB_CONTAINER_NAME=documents

# ── OCR (azure_di | doctr) ──
OCR_PROVIDER=azure_di
OCR_AZURE_ENDPOINT=https://your-di.cognitiveservices.azure.com/
OCR_AZURE_KEY=

# ── Embedding ──
EMBEDDING_AZURE_ENDPOINT=https://your-resource.openai.azure.com/
EMBEDDING_AZURE_API_KEY=
EMBEDDING_AZURE_DEPLOYMENT=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=16

# ── Chunking ──
CHUNK_TARGET_TOKENS=450
CHUNK_MAX_TOKENS=600
CHUNK_OVERLAP_TOKENS=60
CHUNK_ENABLE_SEMANTIC_BOUNDARY=false

# ── PostgreSQL + pgvector ──
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=betterrag
PGVECTOR_USER=betterrag
PGVECTOR_PASSWORD=changeme
PGVECTOR_POOL_SIZE=20
PGVECTOR_POOL_MAX_OVERFLOW=10
PGVECTOR_HNSW_M=24
PGVECTOR_HNSW_EF_CONSTRUCTION=200
PGVECTOR_HNSW_EF_SEARCH=200

# ── Neo4j ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# ── Cache TTLs (seconds) ──
CACHE_HYDE_TTL=3600
CACHE_RBAC_TTL=300
CACHE_QUERY_TTL=120

# ── Poller / Delta Sync ──
DELTA_SYNC_INTERVAL_MINUTES=15
DELTA_TOKEN_MAX_AGE_DAYS=25
INGESTION_MAX_RETRIES=3

# ── Webhook ──
PUBLIC_BASE_URL=https://rag.contoso.com
WEBHOOK_CLIENT_STATE=

# ── API Auth ──
BETTER_RAG_API_KEY=

# ── Open WebUI SSO ──
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
